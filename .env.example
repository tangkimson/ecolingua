# ===== Database (PostgreSQL: local + production) =====
# Local Docker example:
# POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ecolingua?schema=public"
# Managed DB example (Neon/Supabase/Railway):
# POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require&schema=public"
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ecolingua?schema=public"

# ===== NextAuth =====
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_long_random_secret"
TOTP_ENCRYPTION_KEY="replace_with_another_long_random_secret"

# ===== Turnstile CAPTCHA =====
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Optional local testing:
# CAPTCHA_BYPASS="true"

# ===== Cloudinary Uploads =====
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="ecolingua/posts"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ===== Optional upload/rate limit infra (Upstash free tier) =====
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===== Optional Cloudinary quota alert webhook =====
CLOUDINARY_WEBHOOK_SIGNING_SECRET=""

# ===== Public =====
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== Optional seed credentials =====
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
