# ===== Database (PostgreSQL: local + production) =====
# Local Docker example:
# POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ecolingua?schema=public"
# Managed DB example (Neon/Supabase/Railway):
# POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require&schema=public"
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/ecolingua?schema=public"

# ===== NextAuth =====
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_long_random_secret"
TOTP_ENCRYPTION_KEY="replace_with_another_long_random_secret"

# ===== Admin notification =====
ADMIN_NOTIFICATION_EMAIL="xanhvietnam.org@gmail.com"

# ===== Resend email =====
RESEND_API_KEY=""
RESEND_FROM_EMAIL="EcoLingua <onboarding@resend.dev>"

# ===== Public =====
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== Optional seed credentials =====
SEED_ADMIN_EMAIL="admin@xanhvietnam.local"
SEED_ADMIN_PASSWORD="Admin@12345"
